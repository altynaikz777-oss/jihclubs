rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isHead() {
      return signedIn() && currentUser().data.role == 'head';
    }

    function announcementFieldsAreValid() {
      return request.resource.data.keys().hasOnly([
          'id',
          'title',
          'description',
          'createdAt',
          'createdBy',
          'creatorName',
        ]) &&
        request.resource.data.id is string &&
        request.resource.data.id == request.resource.id &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() > 0 &&
        request.resource.data.createdBy is string &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.creatorName is string &&
        request.resource.data.creatorName.size() > 0;
    }

    function attendeeOnlyUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['attendeeUids']) &&
        request.resource.data.attendeeUids is list;
    }

    match /users/{uid} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == uid;
      allow update, delete: if signedIn() && request.auth.uid == uid;
    }

    match /clubs/{clubId} {
      allow read: if signedIn();
      allow create: if isHead() && request.resource.data.adminUid == request.auth.uid;
      allow update, delete: if isHead() && resource.data.adminUid == request.auth.uid;
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if isHead() &&
        request.resource.data.createdBy == request.auth.uid &&
        get(/databases/$(database)/documents/clubs/$(request.resource.data.clubId)).data.adminUid == request.auth.uid;
      allow update: if (isHead() && resource.data.createdBy == request.auth.uid) ||
        (signedIn() && attendeeOnlyUpdate());
      allow delete: if isHead() && resource.data.createdBy == request.auth.uid;
    }

    match /announcements/{announcementId} {
      allow read: if signedIn();
      allow create: if isHead() && announcementFieldsAreValid();
      allow update: if isHead() &&
        resource.data.createdBy == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'description']) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() > 0 &&
        request.resource.data.description is string &&
        request.resource.data.description.size() > 0;
      allow delete: if isHead() && resource.data.createdBy == request.auth.uid;
    }
  }
}
